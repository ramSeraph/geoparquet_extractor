{
  "name": "geoparquet-extractor",
  "version": "0.1.0",
  "description": "Extract and convert spatial data from remote GeoParquet files. Supports bbox filtering, multiple output formats, and pluggable metadata providers.",
  "type": "module",
  "main": "dist/geoparquet-extractor.js",
  "module": "dist/geoparquet-extractor.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/geoparquet-extractor.js",
      "types": "./dist/types/index.d.ts"
    },
    "./gpkg-worker": "./dist/gpkg_worker.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && npm run types",
    "types": "tsc --project jsconfig.json --declaration --emitDeclarationOnly --allowJs --outDir dist/types",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "geoparquet",
    "parquet",
    "geospatial",
    "gis",
    "extract",
    "download",
    "duckdb",
    "wasm",
    "geopackage",
    "shapefile",
    "geojson",
    "kml",
    "csv"
  ],
  "author": "",
  "license": "Unlicense",
  "peerDependencies": {
    "duckdb-wasm-opfs-tempdir": ">=1.33.0"
  },
  "peerDependenciesMeta": {
    "duckdb-wasm-opfs-tempdir": {
      "optional": true
    }
  },
  "dependencies": {
    "hyparquet": "^1.25.0",
    "hyparquet-compressors": "^1.0.0",
    "wa-sqlite-rtree": "^1.0.9"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
